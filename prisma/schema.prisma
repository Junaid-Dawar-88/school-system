generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  PARENT
}

// ─── Organization (Tenant) ───────────────────────────────────
model Organization {
  id         String   @id @default(uuid())
  name       String
  inviteCode String   @unique @default(uuid())
  createdAt  DateTime @default(now())

  ownerId String @unique
  owner   User   @relation("OrgOwner", fields: [ownerId], references: [id])

  users          User[]          @relation("OrgMembers")
  classes        Class[]
  students       Student[]
  attendances    Attendance[]
  complaints     Complaint[]
  notifications  Notification[]
}

// ─── User ────────────────────────────────────────────────────
model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String
  role           Role
  subject        String?
  loginCode      String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation("OrgMembers", fields: [organizationId], references: [id])

  ownedOrg Organization? @relation("OrgOwner")

  classAssignments ClassTeacher[]
  students         Student[]
  complaintsCreated Complaint[]      @relation("ComplaintCreator")
  complaintReplies  ComplaintReply[]
  notifications     Notification[]
}

// ─── Class ───────────────────────────────────────────────────
model Class {
  id   String @id @default(uuid())
  name String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  teachers    ClassTeacher[]
  students    Student[]
  attendances Attendance[]

  createdAt DateTime @default(now())

  @@unique([name, organizationId])
}

// ─── Class-Teacher ───────────────────────────────────────────
model ClassTeacher {
  id      String @id @default(uuid())
  subject String

  classId   String
  class     Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classId, teacherId, subject])
}

// ─── Student ─────────────────────────────────────────────────
model Student {
  id         String @id @default(uuid())
  name       String
  rollNumber String
  fatherName String

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  parentId String?
  parent   User?   @relation(fields: [parentId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  attendances Attendance[]
  complaints  Complaint[]  @relation("ComplaintStudent")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Attendance ──────────────────────────────────────────────
model Attendance {
  id     String           @id @default(uuid())
  date   DateTime
  status AttendanceStatus

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  classId String
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([studentId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

// ─── Complaint ───────────────────────────────────────────────
model Complaint {
  id         String              @id @default(uuid())
  message    String
  type       ComplaintType
  visibility ComplaintVisibility @default(PUBLIC)

  createdById String
  createdBy   User   @relation("ComplaintCreator", fields: [createdById], references: [id])

  studentId String?
  student   Student? @relation("ComplaintStudent", fields: [studentId], references: [id], onDelete: Cascade)

  teacherId String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  replies ComplaintReply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ComplaintType {
  ABOUT_STUDENT
  ABOUT_TEACHER
}

enum ComplaintVisibility {
  PUBLIC
  PRIVATE
}

// ─── Complaint Reply ─────────────────────────────────────────
model ComplaintReply {
  id      String @id @default(uuid())
  message String

  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Notification ────────────────────────────────────────────
model Notification {
  id      String           @id @default(uuid())
  title   String
  message String
  read    Boolean          @default(false)
  type    NotificationType

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum NotificationType {
  COMPLAINT
  GENERAL
}
