generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  PARENT
}

// ─── Organization (Tenant) ───────────────────────────────────
model Organization {
  id         String   @id @default(uuid())
  name       String
  inviteCode String   @unique @default(uuid())
  createdAt  DateTime @default(now())

  ownerId String @unique
  owner   User   @relation("OrgOwner", fields: [ownerId], references: [id])

  users          User[]          @relation("OrgMembers")
  classes        Class[]
  students       Student[]
  attendances    Attendance[]
  complaints     Complaint[]
  notifications  Notification[]
  exams          Exam[]
  grades         Grade[]
  reportCards    ReportCard[]
  fees           Fee[]
  feePayments    FeePayment[]
  timetables     Timetable[]
  assignments    Assignment[]
  assignmentSubmissions AssignmentSubmission[]
  libraryBooks   LibraryBook[]
  bookIssues     BookIssue[]
  vehicles       Vehicle[]
  transportAssignments TransportAssignment[]
  events         Event[]
  leaveRequests  LeaveRequest[]
  salaries       Salary[]
}

// ─── User ────────────────────────────────────────────────────
model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String
  role           Role
  subject        String?
  loginCode      String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation("OrgMembers", fields: [organizationId], references: [id])

  ownedOrg Organization? @relation("OrgOwner")

  classAssignments ClassTeacher[]
  students         Student[]
  complaintsCreated Complaint[]      @relation("ComplaintCreator")
  complaintReplies  ComplaintReply[]
  notifications     Notification[]
  exams             Exam[]
  grades            Grade[]           @relation("GradeTeacher")
  timetables        Timetable[]
  assignments       Assignment[]
  leaveRequests     LeaveRequest[]
  salaries          Salary[]
}

// ─── Class ───────────────────────────────────────────────────
model Class {
  id   String @id @default(uuid())
  name String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  teachers    ClassTeacher[]
  students    Student[]
  attendances Attendance[]
  exams       Exam[]
  grades      Grade[]
  reportCards ReportCard[]
  fees        Fee[]
  timetables  Timetable[]
  assignments Assignment[]

  createdAt DateTime @default(now())

  @@unique([name, organizationId])
}

// ─── Class-Teacher ───────────────────────────────────────────
model ClassTeacher {
  id      String @id @default(uuid())
  subject String

  classId   String
  class     Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classId, teacherId, subject])
}

// ─── Student ─────────────────────────────────────────────────
model Student {
  id         String @id @default(uuid())
  name       String
  rollNumber String
  fatherName String

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  parentId String?
  parent   User?   @relation(fields: [parentId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  attendances Attendance[]
  complaints  Complaint[]  @relation("ComplaintStudent")
  grades      Grade[]
  reportCards ReportCard[]
  feePayments FeePayment[]
  assignmentSubmissions AssignmentSubmission[]
  bookIssues  BookIssue[]
  transportAssignments TransportAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Attendance ──────────────────────────────────────────────
model Attendance {
  id     String           @id @default(uuid())
  date   DateTime
  status AttendanceStatus

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  classId String
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([studentId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

// ─── Complaint ───────────────────────────────────────────────
model Complaint {
  id         String              @id @default(uuid())
  message    String
  type       ComplaintType
  visibility ComplaintVisibility @default(PUBLIC)

  createdById String
  createdBy   User   @relation("ComplaintCreator", fields: [createdById], references: [id])

  studentId String?
  student   Student? @relation("ComplaintStudent", fields: [studentId], references: [id], onDelete: Cascade)

  teacherId String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  replies ComplaintReply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ComplaintType {
  ABOUT_STUDENT
  ABOUT_TEACHER
}

enum ComplaintVisibility {
  PUBLIC
  PRIVATE
}

// ─── Complaint Reply ─────────────────────────────────────────
model ComplaintReply {
  id      String @id @default(uuid())
  message String

  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Exam / Test ─────────────────────────────────────────────
model Exam {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  subject     String

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  grades Grade[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Notification ────────────────────────────────────────────
model Notification {
  id      String           @id @default(uuid())
  title   String
  message String
  read    Boolean          @default(false)
  type    NotificationType

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum NotificationType {
  COMPLAINT
  EXAM
  GENERAL
}

// ─── Grade ───────────────────────────────────────────────────
model Grade {
  id       String @id @default(uuid())
  score    Float
  maxScore Float  @default(100)
  grade    String?
  remarks  String?
  subject  String

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  classId String
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  examId String
  exam   Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   User @relation("GradeTeacher", fields: [teacherId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, examId, subject])
}

// ─── Report Card ─────────────────────────────────────────────
model ReportCard {
  id         String @id @default(uuid())
  term       String
  year       Int
  totalScore Float
  maxTotal   Float
  percentage Float
  rank       Int?
  remarks    String?

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  classId String
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, term, year])
}

// ─── Fee ─────────────────────────────────────────────────────
model Fee {
  id      String   @id @default(uuid())
  title   String
  amount  Float
  dueDate DateTime

  classId String
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  payments FeePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Fee Payment ─────────────────────────────────────────────
model FeePayment {
  id            String        @id @default(uuid())
  amountPaid    Float
  paidDate      DateTime      @default(now())
  status        PaymentStatus @default(PENDING)
  receiptNumber String?

  feeId String
  fee   Fee @relation(fields: [feeId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
}

// ─── Timetable ───────────────────────────────────────────────
model Timetable {
  id        String @id @default(uuid())
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  subject   String
  room      String?

  classId String
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   User @relation(fields: [teacherId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, dayOfWeek, startTime])
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ─── Assignment ──────────────────────────────────────────────
model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  subject     String

  classId String
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   User @relation(fields: [teacherId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  submissions AssignmentSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Assignment Submission ───────────────────────────────────
model AssignmentSubmission {
  id          String   @id @default(uuid())
  content     String?
  submittedAt DateTime @default(now())
  grade       Float?
  feedback    String?

  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assignmentId, studentId])
}

// ─── Library Book ────────────────────────────────────────────
model LibraryBook {
  id              String @id @default(uuid())
  title           String
  author          String
  isbn            String?
  category        String?
  totalCopies     Int    @default(1)
  availableCopies Int    @default(1)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  issues BookIssue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Book Issue ──────────────────────────────────────────────
model BookIssue {
  id         String    @id @default(uuid())
  issueDate  DateTime  @default(now())
  dueDate    DateTime
  returnDate DateTime?
  fine       Float?

  bookId String
  book   LibraryBook @relation(fields: [bookId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Vehicle ─────────────────────────────────────────────────
model Vehicle {
  id            String @id @default(uuid())
  vehicleNumber String
  driverName    String
  driverPhone   String
  capacity      Int
  route         String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignments TransportAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Transport Assignment ────────────────────────────────────
model TransportAssignment {
  id       String @id @default(uuid())
  stopName String

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vehicleId, studentId])
}

// ─── Event ───────────────────────────────────────────────────
model Event {
  id          String    @id @default(uuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  type        EventType

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EventType {
  HOLIDAY
  EVENT
  MEETING
  EXAM_SCHEDULE
}

// ─── Leave Request ───────────────────────────────────────────
model LeaveRequest {
  id        String      @id @default(uuid())
  startDate DateTime
  endDate   DateTime
  reason    String
  status    LeaveStatus @default(PENDING)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Salary ──────────────────────────────────────────────────
model Salary {
  id       String        @id @default(uuid())
  amount   Float
  month    Int
  year     Int
  status   PaymentStatus @default(PENDING)
  paidDate DateTime?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month, year])
}
